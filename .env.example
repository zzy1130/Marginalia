ANTHROPIC_API_KEY=your-api-key-here
ANTHROPIC_BASE_URL=https://coding.dashscope.aliyuncs.com/apps/anthropic
MODEL=qwen3.5-plus

# Sandbox configuration
# auto = try local Docker first, fallback to cloud
# local = require local Docker, fail if unavailable
# cloud = use api.opensandbox.io
# disabled = no sandbox (reduced security)
SANDBOX_MODE=auto
OPENSANDBOX_API_KEY=
OPENSANDBOX_DOMAIN=api.opensandbox.io
